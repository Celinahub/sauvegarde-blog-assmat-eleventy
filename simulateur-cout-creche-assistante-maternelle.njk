  console.log("Contenu à exporter :", element.innerHTML); // Debug

  if (!element || element.classList.contains("d-none") || !element.innerHTML.trim()) {
    alert("Aucun résultat à exporter. Lancez d'abord une simulation.");
    return;
  }

 const opt = {
  margin: [5, 5, 5, 5],
  filename: 'estimation-CMG.pdf',
